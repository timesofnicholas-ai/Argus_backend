REDIS_URL=rediss://default:gQAAAAAAAe_ZAAIgcDFiMmM5MjI0ZTdmY2Q0YzdhYTA5ZGZhYmQzMTAzOTA5OQ@relaxed-flamingo-126937.upstash.io:6379

# Postgres (Supabase connection string, session mode)
DATABASE_URL=postgresql://postgres:FJmlCkECDQFyggcWngYpwGhzZcUfyKAp@postgres.railway.internal:5432/railway

# Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3-flash-preview

# --- Gemini quota, as observed on the API key dashboard ---
# RPD is the binding constraint (45/20 observed = over budget). Do not raise
# these past your actual plan limits — raise the plan first, then these.
GEMINI_RPM_LIMIT=4          # leave 1 RPM of headroom under the plan's 5
GEMINI_RPD_LIMIT=20         # hard daily cap
GEMINI_RPD_RESERVED_FOR_BRIEF=2   # reserve 2 calls/day for WF-08, rest go to enrichment

# enqueue-api
ENQUEUE_API_PORT=3001

# Worker concurrency
CLEANING_CONCURRENCY=20
ENTITY_RESOLUTION_CONCURRENCY=10

# LLM batching
LLM_BATCH_SIZE=20
LLM_BATCH_WINDOW_MS=10000
